		loadExamples testing.ex 

		# set learning and display parameters
		setObj learningRate 0.02
		setObj momentum	    0
		setObj batchSize    0
		setObj numUpdates   10
		setObj randRange 	0.1
		
		# create a function that saves the errors for each example
  	  proc saveActivations {fname} { 
      	  set outfile [open $fname a] 
      	  set num  [getObj currentExample.num]
      	  set name [getObj currentExample.name]
       	 puts -nonewline $outfile "$num $name "
       	 puts $outfile [getObj exampleError]
       	 close $outfile 
    	}

        # run testing set and save activations
        proc testAllFinalActs {fname} { 
            resetExampleSet [getObj testingSet.name] 
            set nex [getObj testingSet.numExamples] 
            for {set i 0} {$i < $nex} {incr i} {
                doExample -set [getObj testingSet.name]
                saveActivations $fname 
            }
        }

        # simulate multiple "participants"
        proc testNetwork {n trainingSet trainNum testingSet fname} {
            for {set i 0} {$i < $n} {incr i} {
                resetNet 
